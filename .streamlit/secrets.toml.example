# Voorbeeld van de secrets. NIET dit bestand gebruiken voor echte waarden.
#
# - LOKAAL testen met wachtwoord: kopieer dit naar .streamlit/secrets.toml
#   en vul je waarden in (dat bestand staat in .gitignore, blijft dus privé).
# - ONLINE (Streamlit Community Cloud): plak deze regels in het
#   "Secrets"-veld van je app (Settings -> Secrets). NIET in GitHub zetten.

# Wachtwoord waarmee collega's de online versie openen:
app_wachtwoord = "kies-hier-een-wachtwoord"

# Je Anthropic API-sleutel (voor de chatfunctie):
ANTHROPIC_API_KEY = "sk-ant-..."
